# ── Database ────────────────────────────────────────────────────────────────
# Dev (Windows): local Docker Postgres published on 127.0.0.1:5433
#   postgresql://hq:hq@127.0.0.1:5433/hq
# Prod (VPS): docker-compose.yml overrides this to the internal `postgres` host.
DATABASE_URL=postgresql://hq:hq@127.0.0.1:5433/hq

# ── Google OAuth (zero-trust sign-in) ───────────────────────────────────────
# Google Cloud Console → Credentials → OAuth 2.0 Client ID (Web application).
# Authorized redirect URIs must include:
#   dev:  http://localhost:3000/api/auth/callback/google
#   prod: https://hq.al-kamal.net/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# The ONLY Google account allowed to sign in. Everyone else is rejected
# server-side regardless of what they do in the browser.
ALLOWED_EMAIL=yazan@al-kamal.net

# Public origin of the app (no trailing slash).
#   dev:  http://localhost:3000
#   prod: https://hq.al-kamal.net
APP_URL=http://localhost:3000

# Postgres credentials for the compose file (prod).
POSTGRES_USER=hq
POSTGRES_PASSWORD=hq
POSTGRES_DB=hq
